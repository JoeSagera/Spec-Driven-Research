{
  "sdr-orchestrator": {
    "description": "SDR Orchestrator - coordinates research phases",
    "mode": "primary",
    "model": "openai/gpt-5.5",
    "prompt": "{file:~/.config/opencode/prompts/sdr/sdr-orchestrator.md}",
    "permission": {
      "task": {
        "*": "deny",
        "sdr-init": "allow",
        "sdr-explore": "allow",
        "sdr-propose": "allow",
        "sdr-spec": "allow",
        "sdr-design": "allow",
        "sdr-tasks": "allow",
        "sdr-verify": "allow",
        "sdr-source-of-truth": "allow"
      }
    }
  },
  "sdr-init": {
    "description": "SDR founder intake and setup",
    "hidden": true,
    "mode": "subagent",
    "model": "openai/gpt-5.5",
    "prompt": "{file:~/.config/opencode/prompts/sdr/sdr-init.md}",
    "tools": { "bash": true, "read": true, "write": true, "edit": true, "glob": true, "grep": true, "webfetch": true, "engram_mem_save": true, "engram_mem_search": true, "engram_mem_get_observation": true }
  },
